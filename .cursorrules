  requiredProp: string;
  optionalProp?: number;
  onAction?: () => void;
}

export default function MyComponent({ requiredProp, optionalProp, onAction }: MyComponentProps) {
  // 1. Hooks (state, effects, context)
  // 2. Derived state/values (useMemo)
  // 3. Event handlers (useCallback)
  // 4. Effects (useEffect)
  // 5. Early returns (loading, error states)
  // 6. Render
  return (
    // JSX
  );
}
```

## API Calling Rules (Redux Toolkit Query)

### CRITICAL: Use RTK Query for ALL API calls
- NO direct fetch/axios calls
- Create separate service files for different domains
- Use customFetchBase for authentication and headers
- One service file per domain

### Service File Structure
```typescript
import { createApi } from '@reduxjs/toolkit/query/react';
import customFetchBase from '@/lib/customFetchBase';
import type { ResponseType, RequestType } from '@/types/[domain].types';

export const [domain]Api = createApi({
  reducerPath: '[domain]Api',
  baseQuery: customFetchBase,
  tagTypes: ['[DomainTag]'],
  endpoints: (builder) => ({
    // Define endpoints here
  }),
});

export const {
  use[Action][Entity]Query,
  use[Action][Entity]Mutation,
} = [domain]Api;
```

### Service File Naming
- Service files: `[domain].service.ts` (e.g., `mediation.service.ts`)
- Export: `[domain]Api` (e.g., `mediationApi`)
- reducerPath: `'[domain]Api'`
- tagTypes: `['[DomainTag]']`

## State Management
- Use RTK Query for server state (all API data)
- Use Redux Toolkit slices for global client state
- Use React Context for theme/auth/global settings
- Use local useState for component-specific state
- Keep state as close to where it's used as possible

### Prop Drilling â€” CRITICAL Rule
- **NEVER pass props more than 2 component levels deep** â€” this is prop drilling and makes code hard to read and maintain
- If a prop needs to go through 3+ levels, use one of these instead:
  - **React Context** (`src/state/contexts/`) â€” for feature-scoped shared state (e.g., a form wizard, a modal flow, a page-level state shared by sibling components)
  - **Redux slice** (`src/state/slices/`) â€” for state used across multiple pages or features, or state that needs to persist
- Decision guide:
  - Shared within a single feature/page tree â†’ use Context
  - Shared across features/pages or needs persistence â†’ use Redux slice
  - Only needed in one component â†’ use local `useState`
- Never create a Redux slice just to avoid lifting state one level â€” use Context for local sharing

## Custom Hooks Pattern
```typescript
interface UseFeatureProps {
  id?: string;
  onSuccess?: () => void;
}

export function useFeature({ id, onSuccess }: UseFeatureProps) {
  // RTK Query hooks
  const { data, isLoading, error } = useGetFeatureQuery(id!, { skip: !id });
  const [createMutation, { isLoading: isCreating }] = useCreateFeatureMutation();
  
  // Local state
  const [localState, setLocalState] = useState();
  
  // Derived state
  const computedValue = useMemo(() => {
    // computation
  }, [data]);
  
  // Handlers
  const handleAction = useCallback(async () => {
    try {
      await createMutation(payload).unwrap();
      onSuccess?.();
    } catch (e) {
      // error handling
    }
  }, [createMutation, onSuccess]);
  
  return {
    data,
    isLoading,
    error,
    computedValue,
    handleAction,
  };
}
```

## UI Components

We use `@frontend-team/ui-kit` for all UI. Before writing any UI code:
1. Read `UI_KIT.md` in `.agents/skills/ui-kit/` for all available components and their APIs.
2. ALWAYS import from `@frontend-team/ui-kit` (not sub-paths).
3. ALWAYS use design token classes (`bg_primary`, `text_secondary`, etc.) â€” never raw Tailwind colors.
4. Do NOT install or use shadcn, MUI, Ant Design or other UI libs â€” use our kit only.

## Styling Rules
- Use `@frontend-team/ui-kit` components instead of custom UI components when possible
- Use Tailwind for layout and spacing utilities only
- NEVER use raw Tailwind color classes â€” always use design token classes from the ui-kit
- Keep Tailwind classes readable (max 5-6 classes per element)
- Avoid inline styles unless necessary for dynamic values

## Error Handling
- Implement proper error boundaries for route-level errors
- Use try-catch blocks for async operations
- Show user-friendly error messages using `toast` from `@frontend-team/ui-kit`
- Log errors for debugging (console.error in development)
- Handle loading and error states in RTK Query hooks

## Environment Variables
- Use `VITE_` prefix for all environment variables
- Define types in `src/env.d.ts`
- Use `import.meta.env` instead of `process.env`
- Always provide fallback values for environment variables

## Variable Naming
- Use camelCase for variables and functions
- Use PascalCase for components, interfaces, and types
- Use UPPER_SNAKE_CASE for constants
- Boolean variables should start with `is`, `has`, `can`, `should`
- Handler functions should start with `handle` (e.g., `handleSubmit`)

## Code Quality
- Keep functions small and focused (< 50 lines ideally)
- Write self-documenting code
- Use meaningful variable and function names
- Remove unused imports and variables
- No console.log in production code (use console.error for errors if needed)
- Add JSDoc comments for complex functions and public APIs

## What to Avoid
- Using Next.js specific imports or patterns
- Relative imports when path aliases are available
- Inline type definitions in component props
- Business logic in components
- Direct API calls without RTK Query
- `any` type (use proper interfaces)
- Files longer than 200 lines
- Duplicate code (extract to hooks/utilities)
- Using Ant Design, shadcn, MUI, or any UI library other than `@frontend-team/ui-kit`
- Raw Tailwind color classes (`bg-white`, `text-gray-900`) â€” use design tokens instead
- Importing from ui-kit sub-paths (always import from `@frontend-team/ui-kit`)
- **Prop drilling** â€” passing props more than 2 levels deep; use Context or Redux slice instead

## Preferred Libraries
- UI: `@frontend-team/ui-kit` (internal â€” do NOT use Ant Design, shadcn, or MUI)
- Forms: React Hook Form + Zod
- State: Redux Toolkit Query + Redux Toolkit
- Routing: React Router DOM
- HTTP: RTK Query (not fetch/axios directly)
- Icons: icons exported from `@frontend-team/ui-kit` or @phosphor-icons/react
- Styling: Tailwind CSS + `@frontend-team/ui-kit` design tokens

## Keycloak SSO Integration
- SSO endpoint: `https://sso.ikameglobal.com`
- Token is passed via hash fragment: `#ssoToken={token}`
- Extract token using `extractTokenFromHash()` from `@/lib/keycloak`
- Use `redirectToSSO(urlDirect)` to redirect users to login
- Token is automatically attached to API requests via `customFetchBase`

## When Writing Code
1. Check file size - if > 200 lines, split it
2. Extract logic to hooks - components should only render UI
3. Use path aliases - never use relative imports when alias is available
4. Use RTK Query - never use fetch/axios directly
5. Define types separately - never inline types in props
6. Follow import order - React â†’ Third-party â†’ Internal (@/) â†’ Relative
7. Use proper naming - follow conventions strictly
8. Handle errors - use try-catch and toast from `@frontend-team/ui-kit`
9. Keep components focused - single responsibility principle
10. Extract reusable logic - create custom hooks or utilities
11. **Avoid prop drilling** - if props go more than 2 levels deep, use Context (feature-scoped) or Redux slice (global/cross-feature)
